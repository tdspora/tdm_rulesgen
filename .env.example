RULESGEN_ENV=local
RULESGEN_APP_NAME=rulesgen
RULESGEN_APP_VERSION=0.1.0
RULESGEN_DOCS_ENABLED=true
RULESGEN_AUTH_ENABLED=false
RULESGEN_API_KEY=change-me
RULESGEN_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000
RULESGEN_TRUSTED_HOSTS=localhost,127.0.0.1
RULESGEN_LOG_LEVEL=INFO
RULESGEN_PROBLEM_BASE_URL=https://docs.rulesgen.local/problems
RULESGEN_DSL_MAX_LENGTH=2000
RULESGEN_DSL_MAX_DEPTH=12
RULESGEN_DSL_MAX_NODES=128
RULESGEN_RULES_REPOSITORY_DIR=.rulesgen-data/rules
RULESGEN_JOBS_REPOSITORY_DIR=.rulesgen-data/jobs
RULESGEN_ARTIFACTS_REPOSITORY_DIR=.rulesgen-data/artifacts
RULESGEN_AUDITS_REPOSITORY_DIR=.rulesgen-data/audits
RULESGEN_OSSFS_ROOT_DIR=.rulesgen-data/ossfs
RULESGEN_SANDBOX_BACKEND=subprocess
RULESGEN_SANDBOX_WORKSPACE_DIR=.rulesgen-data/opensandbox
RULESGEN_SANDBOX_TIMEOUT_SECONDS=30
RULESGEN_SANDBOX_PYTHON_EXECUTABLE=python
RULESGEN_OPENSANDBOX_DOMAIN=localhost:8080
RULESGEN_OPENSANDBOX_PROTOCOL=http
RULESGEN_OPENSANDBOX_API_KEY=
RULESGEN_OPENSANDBOX_REQUEST_TIMEOUT_SECONDS=30
RULESGEN_OPENSANDBOX_USE_SERVER_PROXY=false
RULESGEN_OPENSANDBOX_IMAGE=rulesgen:local
RULESGEN_OPENSANDBOX_TTL_SECONDS=600
RULESGEN_OPENSANDBOX_READY_TIMEOUT_SECONDS=30
RULESGEN_OPENSANDBOX_WORKSPACE_DIR=/tmp/rulesgen-opensandbox
RULESGEN_LLM_GATEWAY_BACKEND=stub
RULESGEN_LLM_GATEWAY_URL=
RULESGEN_LLM_GATEWAY_TIMEOUT_SECONDS=10
RULESGEN_LLM_PROMPT_TEMPLATE_VERSION=v1
RULESGEN_LLM_MODEL_NAME=rulesgen-local-stub
