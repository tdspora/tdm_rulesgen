RULESGEN_ENV=local
RULESGEN_APP_NAME=rulesgen
RULESGEN_APP_VERSION=0.1.0
RULESGEN_DOCS_ENABLED=true
RULESGEN_AUTH_ENABLED=false
RULESGEN_API_KEY=change-me
RULESGEN_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000
RULESGEN_TRUSTED_HOSTS=localhost,127.0.0.1
RULESGEN_LOG_LEVEL=INFO
RULESGEN_PROBLEM_BASE_URL=https://docs.rulesgen.local/problems
RULESGEN_DSL_MAX_LENGTH=2000
RULESGEN_DSL_MAX_DEPTH=12
RULESGEN_DSL_MAX_NODES=128
